# ========================================================================
# CLAN VIDEO RECOMMENDATION .env.example
# ========================================================================
# Copy this file to .env and fill in real values for your environment.
# NEVER commit .env to Git (it's in .gitignore)
# ========================================================================

# API Keys (KEEP SECRET - NEVER PUSH TO GITHUB)
SARVAM_API_KEY=your-sarvam-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL Database Configuration
# Use read-only user for production recommendation service
PG_HOST=your-database-host
PG_PORT=5432
PG_USER=read_only_user
PG_PASSWORD=your-secure-password
PG_DATABASE=clan_development
DATABASE_URL=postgresql://read_only_user:password@host:5432/database

# Qdrant Vector Database Configuration
QDRANT_MODE=remote
QDRANT_PATH=./qdrant_storage
QDRANT_COLLECTION=clan_videos
EMBED_MODEL=all-MiniLM-L6-v2

# Notification Configuration
REMOTE_NOTIFICATION_SEND_URL=https://your-notification-endpoint/send
REMOTE_NOTIFICATION_TYPE=video_recommendation
REMOTE_NOTIFICATION_TIMEOUT_SECONDS=10
ACCOUNT_ID=1

# OCR Configuration (Optional)
UNSTRUCTURED_OCR_URL=http://your-ocr-service:8000/general/v0/general_file
UNSTRUCTURED_OCR_TIMEOUT=45
UNSTRUCTURED_OCR_MODE=auto

# OCR Processing Settings (with defaults)
OCR_FRAME_INTERVAL=1.0
OCR_SCALE=1.0
OCR_CLEAN_LINES=1
OCR_CLEAN_MODE=relaxed
OCR_DEDUP_LINES=1
OCR_DEBUG=1
OCR_CROP_RATIO=0.35
OCR_MAX_FRAMES=0
OCR_DEDUP_SIMILARITY=0.75
OCR_SKIP_SAME_FRAME=0
OCR_HASH_SIZE=8
OCR_PRESERVE_PARENS=1

# Campaign Configuration
CAMPAIGN_DAY_MIN=1
CAMPAIGN_DAY_MAX=22

# JWT Secret (for future API authentication)
# JWT_SECRET_KEY=your-jwt-secret-key-here

# HuggingFace Token (Optional - for higher rate limits on model downloads)
# HF_TOKEN=your-huggingface-token-here
